{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "uplink",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "uplink"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "uplink-db",
      "database_id": "779b2a59-50c9-4378-bfa9-b6d96ac4d692",
      "migrations_dir": "drizzle/migrations"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV_BINDING",
      "id": "d14e5f2da43a43d18c1d5ad068c92d02"
    }
  ],
  "vars": {
    "AUTH_TRUST_HOST": "true",
    "NEXTAUTH_URL": "https://uplink.uplinklfg.workers.dev",
    "NEXT_PUBLIC_LIVEKIT_URL": "wss://uplink-sist6urm.livekit.cloud",
    "DISCORD_CLIENT_ID": "1497303962687115294"
  }
}
