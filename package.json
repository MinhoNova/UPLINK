{
  "name": "uplink-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint",
    "db:migrate:local": "wrangler d1 migrations apply uplink-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply uplink-db --remote",
    "db:seed:local": "node scripts/seed-d1.cjs --local",
    "db:seed:remote": "node scripts/seed-d1.cjs --remote"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "2b": "^1.0.0",
    "better-sqlite3": "^12.10.0",
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.26.3",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "gemma": "^1.1.0",
    "livekit-client": "^2.19.0",
    "livekit-server-sdk": "^2.15.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
